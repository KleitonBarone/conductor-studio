# Conductor Studio environment example
# Copy to .env and adjust values for your environment.

# ─────────────────────────────────────────────────────────────
# LLM provider configuration
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=openai_compatible
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=60000

# ─────────────────────────────────────────────────────────────
# Phoenix / runtime
# ─────────────────────────────────────────────────────────────
PHX_SERVER=true
PORT=4000

# ─────────────────────────────────────────────────────────────
# Production-required values
# (not required for default local dev with config/dev.exs)
# ─────────────────────────────────────────────────────────────
# DATABASE_PATH=/absolute/path/to/conductor_studio.db
# SECRET_KEY_BASE=generate-with: mix phx.gen.secret
# PHX_HOST=example.com
# POOL_SIZE=5
# DNS_CLUSTER_QUERY=
